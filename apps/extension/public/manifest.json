{
  "manifest_version": 3,
  "name": "Ghostscript",
  "description": "Invite-based pairing for concealed Discord messaging.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/ghostscript-16.png",
    "32": "icons/ghostscript-32.png",
    "48": "icons/ghostscript-48.png",
    "128": "icons/ghostscript-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/ghostscript-16.png",
      "32": "icons/ghostscript-32.png"
    },
    "default_title": "Ghostscript",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://discord.com/*", "http://localhost/*", "http://127.0.0.1/*"],
  "content_scripts": [
    {
      "matches": ["https://discord.com/channels/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
